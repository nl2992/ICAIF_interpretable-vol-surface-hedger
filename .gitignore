.DS_Store
.venv/
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
results/*
!results/.gitkeep
notebooks/.ipynb_checkpoints/

# Local vendor option-chain drops. Keep generated research summaries, not raw
# proprietary archives or extracted chain files.
data/*.7z
data/raw/

# Regenerable experiment artifacts (large/binary). The reports/ markdown,
# figures and tables are committed as deliverables; checkpoints are not.
artifacts/
checkpoints/

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.out
*.log
*.synctex.gz
*.fdb_latexmk
*.fls
